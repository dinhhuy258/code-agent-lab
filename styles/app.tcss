CodeAgentApp {
    layout: vertical;
}

/* ── Chat View ── */
ChatView {
    height: 1fr;
    padding: 1 0;
}

/* ── User Message Card ── */
UserMessage {
    margin: 1 1 0 1;
    padding: 1 2;
    border: round $primary;
    border-title-color: $primary;
    border-title-style: bold;
    background: $primary 8%;
}

/* ── Agent Message Card ── */
AgentMessage {
    margin: 1 1 0 1;
    padding: 1 2;
    border: round $accent;
    border-title-color: $accent;
    border-title-style: bold;
    background: $accent 8%;
}

/* ── Tool Call ── */
ToolCallMessage {
    margin: 0 2 0 2;
    padding: 0 1;
    color: $text-muted;
}

ToolCallMessage.success {
    color: $success;
}

ToolCallMessage.error {
    color: $error;
}

/* ── Thinking Indicator ── */
ThinkingIndicator {
    margin: 1 1 0 1;
    padding: 1 2;
    color: $text-muted;
}

/* ── Status Bar ── */
StatusBar {
    height: 1;
    padding: 0 2;
    color: $text-muted;
    dock: bottom;
}

/* ── Message Input ── */
MessageInput {
    height: auto;
    max-height: 10;
    min-height: 3;
    margin: 0 1 0 1;
    border: round $primary;
    border-title-color: $primary;
    border-title-style: bold;
    border-subtitle-color: $text-muted;
    padding: 0 1;
}

MessageInput:focus {
    border: round $accent;
    border-title-color: $accent;
}
